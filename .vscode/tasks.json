{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: npm run dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 1,
              "message": 0
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\s*>.*dev",
            "endsPattern": "ready in"
          }
        }
      ]
    }
  ]
}
